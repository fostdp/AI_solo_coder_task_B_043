# =========================================
# 古代金属冶炼遗址污染指纹识别系统
# 环境变量配置模板
#
# 使用方法: 复制为 .env 然后修改
#   cp .env.example .env
# =========================================

# =========================================
# PostgreSQL 数据库
# =========================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=archaeology_pollution
DB_SSLMODE=disable

# =========================================
# Go 后端服务
# =========================================
SERVER_PORT=8080
GIN_MODE=release

# pprof 性能剖析端口
PPROF_PORT=6060
# Prometheus 指标端口
METRICS_PORT=2112

# =========================================
# Nginx
# =========================================
HTTP_PORT=80

# =========================================
# Prometheus
# =========================================
PROM_PORT=9090

# =========================================
# SMTP 告警邮件
# =========================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alert@example.com
SMTP_PASSWORD=yourpassword
SMTP_FROM=alert@example.com
ALERT_RECIPIENTS=admin@example.com,archaeologist@example.com

# =========================================
# XRF 数据模拟器
# =========================================
# 后端 API 地址（Docker内部用 http://backend:8080）
SIM_API_BASE=http://backend:8080
# 遗址数量（0=全部30个）
SIM_NUM_SITES=30
# 持续上报间隔（秒）
SIM_REPORT_INTERVAL=30
# 历史数据起始年
SIM_START_YEAR=2015
# 历史数据年数
SIM_HISTORY_YEARS=10
# 是否持续上报
SIM_CONTINUOUS=true
# 详细日志
SIM_VERBOSE=true

# 污染特征注入（可选，格式:金属类型_属性=值,多个用逗号分隔
# 示例: 铜_Pb=600,铜_Cu=15000,汞_Hg=400
SIM_PROFILE_OVERRIDES=
